# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
desktop.ini
.cursor/

# Large local media buckets (not deployed)
/Bulls Media/

# Local-only program sources (copied into public/images by sync script)
/Coaches/
/Seniors Real/
/juniors/
/juniors real/
/Girls Pro Squad Program/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel (CLI link data — use VERCEL_* secrets in CI instead)
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
